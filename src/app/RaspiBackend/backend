@app.route("/pictures", methods=["GET"])
def get_saved_pictures():
    """
    Scans a specific directory (determined by the 'path' query parameter) 
    within PICTURES_DIR and returns a list of files and folders.
    """
    # Get the desired relative path from the query string, default to root ('')
    # Use request.args.get with type=str to preserve the full URL-encoded string
    relative_path = unquote(request.args.get('path', '', type=str))
    
    # Sanitize the path to prevent directory traversal attacks
    normalized_path = os.path.normpath(relative_path) if relative_path else ''
    
    # Join the base directory with the normalized path
    current_dir = os.path.join(PICTURES_DIR, normalized_path)
    
    # Safety check: ensure we're still within PICTURES_DIR
    try:
        real_current = os.path.realpath(current_dir)
        real_pictures = os.path.realpath(PICTURES_DIR)
        if not is_inside_directory(real_pictures, real_current):
            return jsonify({"error": "Access denied: Path outside pictures directory"}), 403
    except Exception as e:
        return jsonify({"error": f"Path validation failed: {str(e)}"}), 400

    # 1. Validation and Creation Check
    if not os.path.isdir(current_dir):
        # If the path is not the root and is invalid
        if normalized_path != '':
            return jsonify({"error": f"Directory not found: {normalized_path}"}), 404
            
        # If it's the root and doesn't exist, create it
        try:
            os.makedirs(current_dir, exist_ok=True)
            return jsonify({
                "message": f"Pictures directory '{current_dir}' was missing but has been created.",
                "currentPath": '',
                "contents": []
            }), 200
        except OSError as e:
            return jsonify({"error": f"Pictures directory creation failed: {str(e)}"}), 500

    # 2. List Contents
    file_list = []
    try:
        # List all files and directories in the current path
        for item_name in os.listdir(current_dir):
            # Skip hidden files/folders
            if item_name.startswith('.'):
                continue
            
            full_path = os.path.join(current_dir, item_name)
            is_dir = os.path.isdir(full_path)
            
            # Only get details for files; folders just need their name/type
            details = get_file_details(full_path) if not is_dir else {}

            file_list.append({
                'name': item_name,
                'is_folder': is_dir,
                'size': details.get('size'),
                'last_modified': details.get('last_modified')
            })
    except PermissionError:
        return jsonify({"error": f"Permission denied accessing: {current_dir}"}), 403
    except Exception as e:
        return jsonify({"error": f"Error listing directory contents: {str(e)}"}), 500

    # 3. Sort contents (Folders first, then by name)
    file_list.sort(key=lambda x: (not x['is_folder'], x['name'].lower()))

    # 4. Return the structured response
    return jsonify({
        "currentPath": normalized_path,
        "contents": file_list
    }), 200
    
@app.route("/pictures/download", methods=["GET"])
def download_pictures_folder():
    """
    Downloads a folder as a ZIP file.
    Query parameter 'path' specifies which folder to download.
    """
    relative_path = unquote(request.args.get('path', ''))
    
    if not relative_path:
        return jsonify({"error": "No path specified"}), 400
    
    # Sanitize the path to prevent directory traversal attacks
    normalized_path = os.path.normpath(relative_path)
    current_dir = os.path.join(PICTURES_DIR, normalized_path)
    
    # Safety check: ensure we're still within PICTURES_DIR
    try:
        real_current = os.path.realpath(current_dir)
        real_pictures = os.path.realpath(PICTURES_DIR)
        if not is_inside_directory(real_pictures, real_current):
            return jsonify({"error": "Access denied: Path outside pictures directory"}), 403
    except Exception as e:
        return jsonify({"error": f"Path validation failed: {str(e)}"}), 400
    
    # Validate the directory exists
    if not os.path.isdir(current_dir):
        return jsonify({"error": f"Directory not found: {normalized_path}"}), 404
    
    try:
        # Create ZIP file in memory
        zip_buffer = io.BytesIO()
        file_count = 0
        
        with zipfile.ZipFile(zip_buffer, 'w', zipfile.ZIP_DEFLATED) as zip_file:
            # Walk through all files and subdirectories
            for root, dirs, files in os.walk(current_dir):
                print(f"Walking: {root}, files: {len(files)}")
                for file in files:
                    # Skip hidden files
                    if file.startswith('.'):
                        continue
                    
                    try:
                        file_path = os.path.join(root, file)
                        # Calculate the archive name (relative path within the ZIP)
                        arcname = os.path.relpath(file_path, current_dir)
                        print(f"Adding to ZIP: {file_path} as {arcname}")
                        zip_file.write(file_path, arcname)
                        file_count += 1
                    except Exception as file_err:
                        print(f"Error adding file {file}: {str(file_err)}")
                        continue
        
        print(f"ZIP creation complete. Files added: {file_count}")
        zip_buffer.seek(0)
        folder_name = os.path.basename(current_dir) or 'pictures'
        
        return send_file(
            zip_buffer,
            mimetype='application/zip',
            as_attachment=True,
            download_name=f'{folder_name}.zip'
        )
    
    except PermissionError:
        print(f"Permission denied: {current_dir}")
        return jsonify({"error": f"Permission denied accessing: {current_dir}"}), 403
    except Exception as e:
        print(f"ZIP creation error: {str(e)}")
        print(f"Current dir: {current_dir}")
        import traceback
        traceback.print_exc()
        return jsonify({"error": f"Failed to create ZIP: {str(e)}"}), 500
    
@app.route("/api/logs", methods=["GET"])
def get_recent_logs():
    """
    Reads the last N lines (default 50) of the routine scheduler log file.
    """
    try:
        # Check if file exists
        if not os.path.exists(LOG_FILE_PATH):
            return jsonify({"logs": [f"Error: Log file not found at {LOG_FILE_PATH}"], "success": False}), 404

        N = 50 # Number of lines to return

        # Open the file and read all lines
        with open(LOG_FILE_PATH, 'r') as f:
            lines = f.readlines()
        
        # Get the last N lines and strip trailing whitespace/newlines
        recent_lines = [line.strip() for line in lines[-N:]]

        return jsonify({"logs": recent_lines, "success": True}), 200

    except Exception as e:
        print(f"Error reading log file: {str(e)}")
        return jsonify({"logs": [f"Error reading logs: {str(e)}"], "success": False}), 500

# ---------------------------------------------------------------------------
# Live Camera Stream  (MJPEG via multipart/x-mixed-replace)
# ---------------------------------------------------------------------------
_stream_active = False  # simple flag to prevent stacking streams

@app.route('/api/camera/stream')
def camera_stream():
    """
    Streams live MJPEG frames from the Pi camera.
    The browser can consume this directly as an <img src=".../stream"> tag.
    """
    global _stream_active

    try:
        from picamera2 import Picamera2
        import cv2
    except ImportError as e:
        return jsonify({"error": f"Missing library: {e}. Install picamera2 and opencv-python-headless on the Pi."}), 500

    def generate_frames():
        global _stream_active
        if _stream_active:
            # Already streaming - send a single error frame and stop
            return
        _stream_active = True
        picam2 = None
        try:
            picam2 = Picamera2()
            # Use a lower-resolution video config for smooth streaming
            config = picam2.create_video_configuration(
                main={"size": (1280, 720), "format": "RGB888"}
            )
            picam2.configure(config)
            picam2.start()
            time_module.sleep(0.5)  # allow sensor to stabilise

            while True:
                frame = picam2.capture_array()          # RGB numpy array
                ok, jpeg = cv2.imencode(
                    '.jpg', frame,
                    [cv2.IMWRITE_JPEG_QUALITY, 80]
                )
                if not ok:
                    continue
                yield (
                    b'--frame\r\n'
                    b'Content-Type: image/jpeg\r\n\r\n' +
                    jpeg.tobytes() +
                    b'\r\n'
                )
        except GeneratorExit:
            pass  # client disconnected - clean exit
        except Exception as e:
            print(f"[stream] Error during streaming: {e}")
        finally:
            _stream_active = False
            if picam2 is not None:
                try:
                    picam2.stop()
                    picam2.close()
                except Exception:
                    pass

    return Response(
        generate_frames(),
        mimetype='multipart/x-mixed-replace; boundary=frame'
    )


@app.route("/routines/schedule-update", methods=["POST"])
def update_routine_schedule():
    """Updates the schedule (day and time) for an active routine in routine_schedule."""
    data = request.json
    filename = data.get("filename")
    day = data.get("day")
    time = data.get("time")

    if not all([filename, day, time]):
        return jsonify({"error": "Filename, day, or time missing."}), 400
        
    try:
        schedule_day = int(day)
        if not time.count(':') == 1 or len(time) != 5:
            raise ValueError("Time format is invalid. Must be HH:MM.")
            
        conn = get_db_connection()
        cursor = conn.cursor()
        
        cursor.execute("""
            UPDATE routine_schedule 
            SET schedule_day = ?, start_time = ? 
            WHERE filename = ?
        """, (schedule_day, time, filename))
        
        if cursor.rowcount == 0:
            conn.close()
            return jsonify({"error": f"Routine '{filename}' not found in active list."}), 404
            
        conn.commit()
        conn.close()
        return jsonify({"message": f"Schedule for '{filename}' updated to Day {schedule_day} at {time}."}), 200
        
    except ValueError as e:
        return jsonify({"error": str(e)}), 400
    except sqlite3.Error as e:
        conn.close()
        return jsonify({"error": f"Database error: {e}"}), 500
        

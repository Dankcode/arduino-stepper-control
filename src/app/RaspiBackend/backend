# --- Database Helper Functions ---

def get_db_connection():
    """Establishes a connection to the SQLite database."""
    conn = sqlite3.connect(DATABASE_FILE)
    # Set row_factory to sqlite3.Row to allow accessing columns by name
    conn.row_factory = sqlite3.Row 
    return conn

def init_db():
    """Creates the 'well_data' table if it doesn't exist."""
    print("Initializing database...")
    conn = get_db_connection()
    cursor = conn.cursor()
    
    # SQL to create the table based on the data structure uploaded from the frontend
    # Note: 'switchPlate' is stored as INTEGER (0 or 1 for BOOLEAN)
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS well_data (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            filename TEXT NOT NULL,
            plateNumber INTEGER NOT NULL,
            wellId TEXT NOT NULL,
            stepAmount INTEGER,
            delayBetweenStep INTEGER,
            lightTime INTEGER,
            exposureTime INTEGER,
            switchPlate INTEGER,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        );
    """)
    # Create an index for faster lookups based on filename, which will be frequent
    cursor.execute("CREATE INDEX IF NOT EXISTS idx_filename ON well_data (filename);")
    conn.commit()
    conn.close()
    print("Database initialization complete.")
    
def calculate_routine_runtime(routine_name):
    """
    Calculates the total runtime in seconds for a routine based on its well data.
    Formula: SUM( (stepAmount * (delayBetweenStep + lightTime + exposureTime)) )
    """
    conn = get_db_connection()
    # The filename in the DB is the base name (no .sql)
    cursor = conn.execute("""
        SELECT 
            SUM(
                stepAmount * (delayBetweenStep + lightTime + exposureTime)
            ) AS total_runtime
        FROM well_data
        WHERE filename = ?
    """, (routine_name,))
    
    result = cursor.fetchone()
    conn.close()
    
    # Returns the calculated runtime or 0 if NULL/no data
    return result['total_runtime'] if result and result['total_runtime'] is not None else 0


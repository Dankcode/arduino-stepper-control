@app.route("/upload_routine", methods=["POST"])
def upload_routine():
    """
    Accepts an uploaded SQL file and executes the INSERT statements within
    it to store the routine state in the SQLite database.
    """
    try:
        # Check if a file was uploaded with the correct field name 'routine_file'
        if 'routine_file' not in request.files:
            return jsonify({"error": "No file part in the request"}), 400
        
        file = request.files['routine_file']
        
        # If the user does not select a file, the browser submits an
        # empty file without a filename.
        if file.filename == '':
            return jsonify({"error": "No selected file"}), 400
            
        # Check if file has .sql extension (as per frontend change)
        if not file.filename.endswith('.sql'):
            return jsonify({"error": "Only .sql files are allowed for routine upload"}), 400
            
        # 1. Read the content of the uploaded SQL file
        # The file is a FileStorage object, so we read its contents.
        sql_script = file.read().decode('utf-8')
        
        # We assume the frontend has ensured the filename is clean and contains 
        # the routine name (e.g., 'MyRoutine.sql').
        routine_name = file.filename.replace('.sql', '')

        conn = get_db_connection()
        cursor = conn.cursor()

        # 2. Delete existing routine data for the same filename to ensure an 'overwrite'
        # This prevents duplicate well entries on re-upload of the same filename.
        cursor.execute("DELETE FROM well_data WHERE filename = ?", (routine_name,))

        # 3. Execute the SQL script containing the INSERT statements
        # executemany or executescript is used for multiple statements
        # We use executescript as the frontend compiled a complete script
        cursor.executescript(sql_script)

        # 4. Commit the transaction
        conn.commit()
        conn.close()
        
        return jsonify({"message": f"Routine '{routine_name}' data successfully stored in SQLite."}), 200
        
    except sqlite3.Error as e:
        # Handle SQLite-specific errors (e.g., malformed SQL)
        conn.close()
        return jsonify({"error": f"Database Error: {str(e)}"}), 500
        
    except Exception as e:
        # Handle general errors (e.g., file reading, network)
        return jsonify({"error": f"Error processing routine: {str(e)}"}), 500


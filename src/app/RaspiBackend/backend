def get_db_connection():
    """Establishes a connection to the SQLite database."""
    conn = sqlite3.connect(DATABASE_FILE)
    # Allows column access by name (e.g., row['filename'])
    conn.row_factory = sqlite3.Row 
    return conn

def init_db():
    """Creates the necessary tables if they don't exist, establishing parent-child relationships."""
    conn = get_db_connection()
    cursor = conn.cursor()
    
    # 1. PARENT Table: routines (New)
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS routines (
            filename TEXT PRIMARY KEY,       -- Parent key for the routine
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        );
    """)
    # 2. CHILD Table: well_data (Routine Steps)
    # well_data is a CHILD of routines, using ON DELETE CASCADE
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS well_data (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            filename TEXT NOT NULL,         
            plateNumber INTEGER NOT NULL,
            wellId TEXT NOT NULL,
            stepAmount INTEGER,
            delayBetweenStep INTEGER,
            lightTime INTEGER,
            exposureTime INTEGER,
            switchPlate INTEGER,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            -- Foreign Key constraint
            FOREIGN KEY (filename) REFERENCES routines(filename) ON DELETE CASCADE,
            UNIQUE(filename, plateNumber, wellId)
        );
    """)
    
    # 3. CHILD Table: routine_schedule (Active Status/Schedule)
    # routine_schedule is a CHILD of routines, using ON DELETE CASCADE
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS routine_schedule (
            filename TEXT PRIMARY KEY,       
            start_time TEXT,                 -- HH:MM 
            schedule_day INTEGER,            -- Day of the week (1-7, 1=Mon, 7=Sun)
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            -- Foreign Key constraint
            FOREIGN KEY (filename) REFERENCES routines(filename) ON DELETE CASCADE
        );
    """)
    
    conn.commit()
    conn.close()

def _time_to_minutes(schedule_day, start_time):
    # ... (Scheduling helper function, no change) ...
    try: 
        if schedule_day is None or start_time is None:
            return None
        day_minutes = (int(schedule_day) - 1) * 24 * 60 
        h, m = map(int, start_time.split(':'))
        time_minutes = h * 60 + m 
        return day_minutes + time_minutes
    except:
        return None

def _minutes_to_time(total_minutes):
    # ... (Scheduling helper function, no change) ...
    WEEK_MINUTES = 7 * 24 * 60
    norm_minutes = total_minutes % WEEK_MINUTES 
    day = int(norm_minutes // (24 * 60)) + 1
    remaining_minutes = norm_minutes % (24 * 60)
    hour = int(remaining_minutes // 60)
    minute = int(remaining_minutes % 60)
    return day, f"{hour:02d}:{minute:02d}"

def calculate_routine_runtime(routine_name):
    """Calculates the total runtime in seconds from well_data."""
    conn = get_db_connection()
    # Still query well_data, which holds the step information
    cursor = conn.execute("""
        SELECT 
            SUM(
                stepAmount * (delayBetweenStep + lightTime + exposureTime)
            ) AS total_runtime
        FROM well_data
        WHERE filename = ?
    """, (routine_name,))
    result = cursor.fetchone()
    conn.close()
    return result['total_runtime'] if result and result['total_runtime'] is not None else 0

def get_next_available_time():
    """Calculates the earliest available start time for a new routine."""
    # ... (Scheduling logic, no change) ...
    conn = get_db_connection()
    scheduled_routines = conn.execute("SELECT filename, start_time, schedule_day FROM routine_schedule").fetchall()
    conn.close()

    scheduled_data = []
    for row in scheduled_routines:
        start_minutes = _time_to_minutes(row['schedule_day'], row['start_time'])
        if start_minutes is not None:
            runtime = calculate_routine_runtime(row['filename'])
            runtime_minutes = (runtime + 59) // 60 
            
            scheduled_data.append({
                'start_minutes': start_minutes,
                'end_minutes': start_minutes + runtime_minutes,
                'filename': row['filename']
            })

    scheduled_data.sort(key=lambda x: x['start_minutes'])
    
    now = datetime.now()
    current_day = now.weekday() + 1 
    current_time = now.strftime('%H:%M')
    current_minutes = _time_to_minutes(current_day, current_time)

    next_available_minutes = current_minutes
    
    for routine in scheduled_data:
        if routine['end_minutes'] > next_available_minutes:
            next_available_minutes = routine['end_minutes']

    if not scheduled_data and next_available_minutes == current_minutes:
         return current_day, current_time
        
    return _minutes_to_time(next_available_minutes)

@app.route("/routines/data/<string:routine_name>", methods=["GET"])
def get_routine_data(routine_name):
    """
    Fetches all well_data records for a given routine name (for the Edit function).
    The routine_name should be the base name (no .sql extension).
    """
    try:
        conn = get_db_connection()
        cursor = conn.execute("SELECT * FROM well_data WHERE filename = ?", (routine_name,))
        data = [dict(row) for row in cursor.fetchall()]
        conn.close()
        
        if not data:
            return jsonify({"error": f"No data found for routine '{routine_name}'"}), 404
            
        return jsonify(data), 200
    except Exception as e:
        return jsonify({"error": f"Error fetching routine data: {str(e)}"}), 500

@app.route("/routines/delete", methods=["POST"])
def delete_routine():
    """
    Deletes a routine, either from the SQL database (inactive) or the filesystem (active).
    Requires 'filename' in the JSON body.
    """
    data = request.json
    filename = data.get("filename")
    if not filename:
        return jsonify({"error": "Filename not provided."}), 400

    # 1. Check for Active Routine (Filesystem)
    file_path = find_routine_file(filename)
    if file_path and file_path.startswith(ACTIVE_ROUTINES_DIR):
        try:
            os.remove(file_path)
            return jsonify({"message": f"Active routine file '{filename}' deleted successfully."}), 200
        except OSError as e:
            return jsonify({"error": f"Error deleting file: {e}"}), 500

    # 2. Delete from SQL Database (Inactive Routine)
    # The frontend passes the base name for inactive routines
    routine_name_base = filename
    conn = get_db_connection()
    try:
        cursor = conn.cursor()
        cursor.execute("DELETE FROM well_data WHERE filename = ?", (routine_name_base,))
        
        if cursor.rowcount == 0:
            conn.close()
            return jsonify({"error": "Routine not found in database or filesystem."}), 404

        conn.commit()
        conn.close()
        return jsonify({"message": f"Routine '{routine_name_base}' deleted successfully from database."}), 200
    except sqlite3.Error as e:
        conn.close()
        return jsonify({"error": f"Database error during deletion: {e}"}), 500


@app.route("/routines/rename", methods=["POST"])
def rename_routine():
    """
    Renames a routine. If inactive, updates the filename in the SQL database.
    If active, renames the file on the filesystem.
    Requires 'oldName' and 'newName' in the JSON body (both should be base names 
    for inactive routines, or full file names for active).
    """
    data = request.json
    old_name = data.get("oldName")
    new_name = data.get("newName")
    if not old_name or not new_name:
        return jsonify({"error": "Old or new name not provided."}), 400
        
    # 1. Check for Active Routine (Filesystem)
    # The frontend sends the full timestamped name for active routines
    old_path_active = find_routine_file(old_name)
    if old_path_active and old_path_active.startswith(ACTIVE_ROUTINES_DIR):
        # Extract the original name from the timestamped name
        original_base_name = get_routine_name_from_active_filename(old_name).replace('.txt', '')
        
        # Re-construct the new filename with the *original* base name's extension (.txt)
        new_active_filename = old_name.replace(original_base_name, new_name)

        new_path_active = os.path.join(ACTIVE_ROUTINES_DIR, new_active_filename)

        try:
            shutil.move(old_path_active, new_path_active)
            return jsonify({"message": f"Active routine '{old_name}' renamed to '{new_active_filename}' successfully."}), 200
        except Exception as e:
            return jsonify({"error": f"Error renaming active file: {e}"}), 500


    # 2. Rename in SQL Database (Inactive Routine)
    # The frontend sends the base name (no extension)
    conn = get_db_connection()
    try:
        cursor = conn.cursor()
        cursor.execute(
            "UPDATE well_data SET filename = ? WHERE filename = ?", 
            (new_name, old_name)
        )
        
        if cursor.rowcount == 0:
            conn.close()
            return jsonify({"error": "Routine not found in database or filesystem."}), 404
            
        conn.commit()
        conn.close()
        return jsonify({"message": f"Routine '{old_name}' renamed to '{new_name}' successfully in database."}), 200
    except sqlite3.Error as e:
        conn.close()
        return jsonify({"error": f"Database error during renaming: {e}"}), 500        
    

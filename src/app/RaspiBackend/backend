@app.route("/save_routine_sql", methods=["POST"])
def save_routine_sql():
    """
    Saves a new routine by inserting the filename into the PARENT 'routines' table 
    and then the well data into the 'well_data' CHILD table.
    """
    data = request.json
    filename = data.get("filename")
    well_data_list = data.get("well_data", [])

    if not filename or not well_data_list:
        return jsonify({"error": "Filename or well data missing."}), 400

    conn = get_db_connection()
    try:
        conn.execute('BEGIN TRANSACTION;')
        
        # 1. Insert/Replace into PARENT table: routines
        conn.execute("INSERT OR REPLACE INTO routines (filename) VALUES (?)", (filename,))

        # 2. Clear existing well_data for this routine to ensure a clean save/overwrite
        conn.execute("DELETE FROM well_data WHERE filename = ?", (filename,))
        
        # 3. Insert into CHILD table: well_data
        insert_data = [
            (
                filename, d['plateNumber'], d['wellId'], d['stepAmount'], 
                d['delayBetweenStep'], d['lightTime'], d['exposureTime'], d['switchPlate']
            ) for d in well_data_list
        ]

        conn.executemany("""
            INSERT INTO well_data (
                filename, plateNumber, wellId, stepAmount, delayBetweenStep, 
                lightTime, exposureTime, switchPlate
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?)
        """, insert_data)

        conn.commit()
        return jsonify({"message": f"Routine '{filename}' saved successfully."}), 200
        
    except sqlite3.IntegrityError as e:
        conn.rollback()
        return jsonify({"error": f"Integrity error: {e}"}), 400
    except Exception as e:
        conn.rollback()
        return jsonify({"error": f"An unexpected error occurred: {e}"}), 500
    finally:
        conn.close()
@app.route("/routines/all")
def get_all_routines():
    """
    Returns a list of all routines (from PARENT 'routines' table) and active routines 
    (from CHILD 'routine_schedule' table).
    """
    try:
        conn = get_db_connection()
        
        # 1. Get ALL routines from the PARENT table
        all_routines = conn.execute("SELECT filename FROM routines ORDER BY filename;").fetchall()
        
        # 2. Get ACTIVE routine details from routine_schedule
        active_schedule_data = conn.execute("SELECT * FROM routine_schedule;").fetchall()
    
        active_map = {}
        for row in active_schedule_data:
            start_minutes = _time_to_minutes(row['schedule_day'], row['start_time'])
            active_map[row['filename']] = {
                'day': row['schedule_day'],
                'time': row['start_time'],
                'start_minutes': start_minutes,
            }
            
        all_routines_list = []
        active_routines_list = []
        for row in all_routines:
            routine_base_name = row['filename']
            runtime = calculate_routine_runtime(routine_base_name)
     
            if routine_base_name in active_map:
                active_data = active_map[routine_base_name]
                active_routines_list.append({
                    "name": routine_base_name,
                    "day": active_data.get('day'),
                    "time": active_data.get('time'),
                    "totalRuntime": runtime,
                    "start_minutes": active_data.get('start_minutes')
                })
            else:
                all_routines_list.append({
                    "name": routine_base_name + '.sql', 
                    "totalRuntime": runtime
                })

        conn.close()
        
        # 3. Sort the active routines by their start_minutes
        active_routines_list = sorted([
            r for r in active_routines_list if r['start_minutes'] is not None
        ], key=lambda x: x['start_minutes'])
        
        for r in active_routines_list:
            del r['start_minutes']
        
        return jsonify({
            "all_routines": all_routines_list,
            "active_routines": active_routines_list
        }), 200
    except Exception as e:
        return jsonify({"error": str(e)}), 500
@app.route("/routines/rename", methods=["POST"])
def rename_routine():
    """
    Renames the routine in all three tables: routines (parent), well_data, and routine_schedule (children).
    """
    data = request.json
    old_name = data.get("oldName")
    new_name = data.get("newName")
    
    if not old_name or not new_name:
        return jsonify({"error": "Old name or new name not provided."}), 400
        
    if old_name == new_name:
        return jsonify({"message": "Routine name did not change."}), 200

    conn = get_db_connection()
    try:
        conn.execute('BEGIN TRANSACTION;') 
        
        # Check if the old routine exists in the PARENT table
        exists = conn.execute("SELECT 1 FROM routines WHERE filename = ?", (old_name,)).fetchone()
        if not exists:
            conn.rollback()
            return jsonify({"error": f"Routine '{old_name}' not found in the database."}), 404
            
        # Due to SQLite not supporting cascading updates on PRIMARY KEY foreign keys:
        # 1. Update the filename in CHILD tables first
        conn.execute("UPDATE well_data SET filename = ? WHERE filename = ?", (new_name, old_name))
        conn.execute("UPDATE routine_schedule SET filename = ? WHERE filename = ?", (new_name, old_name))
        
        # 2. Delete the old filename entry from PARENT table
        conn.execute("DELETE FROM routines WHERE filename = ?", (old_name,))
        
        # 3. Insert the new filename entry into PARENT table
        conn.execute("INSERT INTO routines (filename) VALUES (?)", (new_name,))
        
        conn.commit()
        conn.close()
        return jsonify({"message": f"Routine '{old_name}' renamed to '{new_name}' successfully."}), 200
        
    except sqlite3.Error as e:
        conn.rollback()
        conn.close() 
        return jsonify({"error": f"Database error during renaming: {e}"}), 500
    except Exception as e:
        conn.close()
        return jsonify({"error": f"An unexpected error occurred: {e}"}), 500
@app.route("/routines/delete", methods=["POST"])
def delete_routine():
    """
    Deletes a routine from the PARENT 'routines' table.
    The ON DELETE CASCADE foreign key constraint handles the deletion from well_data and routine_schedule.
    """
    data = request.json
    filename = data.get("filename")
    if not filename:
        return jsonify({"error": "Filename not provided."}), 400

    conn = get_db_connection()
    try:
        cursor = conn.cursor()
        
        # Delete from the PARENT table
        cursor.execute("DELETE FROM routines WHERE filename = ?", (filename,))
        
        if cursor.rowcount == 0:
            conn.close()
            return jsonify({"error": f"Routine '{filename}' not found."}), 404
            
        conn.commit()
        conn.close()
        # Cascade takes care of well_data and routine_schedule deletion
        return jsonify({"message": f"Routine '{filename}' deleted successfully."}), 200
    except sqlite3.Error as e:
        conn.close()
        return jsonify({"error": f"Database error: {e}"}), 500
@app.route("/routines/move-to-active-sql", methods=["POST"])
def move_to_active_sql():
    """Inserts into routine_schedule CHILD table with the next available start time."""
    data = request.json
    filename = data.get("filename")
    if not filename:
        return jsonify({"error": "Filename not provided."}), 400

    conn = get_db_connection()
    try:
        # Check if the routine exists in PARENT 'routines' table
        exists = conn.execute("SELECT 1 FROM routines WHERE filename = ?", (filename,)).fetchone()
        if not exists:
            conn.close()
            return jsonify({"error": f"Routine '{filename}' not found in the routines master list."}), 404

        schedule_day, start_time = get_next_available_time()

        # Insert into CHILD table: routine_schedule
        cursor = conn.cursor()
        cursor.execute("""
            INSERT OR REPLACE INTO routine_schedule (filename, schedule_day, start_time)
            VALUES (?, ?, ?)
        """, (filename, schedule_day, start_time))
        
        conn.commit()
        conn.close()
        return jsonify({"message": f"Routine '{filename}' set to active in database with schedule day {schedule_day} at {start_time}."}), 200
    except sqlite3.Error as e:
        conn.close()
        return jsonify({"error": f"Database error: {e}"}), 500
